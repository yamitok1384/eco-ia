    "        <div class=\"weight-label\" id=\"w1-inf\" style=\"background:#dcfce7; border:1px solid #16a34a;\">w₁ = Bloqueado</div>\n",
    "        <div class=\"weight-label\" id=\"w2-inf\" style=\"background:#dcfce7; border:1px solid #16a34a;\">w₂ = Bloqueado</div>\n",
    "      </div>\n",
    "      <div class=\"node node-soma\" id=\"soma-inf\" style=\"border-color:#16a34a;\">∑</div>\n",
    "      <div class=\"node node-output\" id=\"out-inf\" style=\"width:auto; padding:0 1rem;\">Predicción</div>\n",
    "    </div>\n",
    "  </div>\n",
    "`;\n",
    "\n",
    "let w1_learned = 0;\n",
    "let w2_learned = 0;\n",
    "\n",
    "function iniciarEntrenamiento() {\n",
    "  const btn = document.getElementById('btn-train');\n",
    "  btn.disabled = true;\n",
    "  btn.innerText = \"Entrenando modelo...\";\n",
    "  \n",
    "  const w1_lbl = document.getElementById('w1-label');\n",
    "  const w2_lbl = document.getElementById('w2-label');\n",
    "  const out_lbl = document.getElementById('out-train');\n",
    "  \n",
    "  w1_lbl.classList.add('learning');\n",
    "  w2_lbl.classList.add('learning');\n",
    "\n",
    "  let iteracion = 0;\n",
    "  // Valores objetivo correctos (w1=2, w2=3 -> 2*2 + 3*3 = 13)\n",
    "  const objetivo = 13;\n",
    "  let temp_w1 = 0;\n",
    "  let temp_w2 = 0;\n",
    "\n",
    "  // Animación del ajuste de pesos (simulando gradiente descendente)\n",
    "  const intervalo = setInterval(() => {\n",
    "    iteracion++;\n",
    "    // Generar pesos aleatorios probando\n",
    "    temp_w1 = Math.floor(Math.random() * 5);\n",
    "    temp_w2 = Math.floor(Math.random() * 5);\n",
    "    \n",
