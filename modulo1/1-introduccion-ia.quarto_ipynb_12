    "<script>\n",
    "const container = document.getElementById('simulador-entrenamiento');\n",
    "\n",
    "container.innerHTML = `\n",
    "  <div class=\"sim-box\" id=\"fase1\">\n",
    "    <div class=\"sim-header\">Fase 1: Entrenamiento (Ajuste de Pesos)</div>\n",
    "    <p style=\"text-align:center; font-size:0.9rem; color:#475569;\">Le damos al modelo datos reales (Entradas) y la respuesta correcta (Objetivo). La IA ajustará sus <strong>pesos</strong> hasta acertar.</p>\n",
    "    \n",
    "    <div class=\"network-graph\">\n",
    "      <div class=\"input-col\">\n",
    "        <div class=\"node node-input\" title=\"Entrada 1\">x₁=2</div>\n",
    "        <div class=\"node node-input\" title=\"Entrada 2\">x₂=3</div>\n",
    "      </div>\n",
    "      <div class=\"weight-col\">\n",
    "        <div class=\"weight-label\" id=\"w1-label\">w₁ = ?</div>\n",
    "        <div class=\"weight-label\" id=\"w2-label\">w₂ = ?</div>\n",
    "      </div>\n",
    "      <div class=\"node node-soma\" id=\"soma-train\">∑</div>\n",
    "      <div class=\"node node-output\" id=\"out-train\">...</div>\n",
    "    </div>\n",
    "\n",
    "    <div class=\"controls\">\n",
    "      <span><strong>Objetivo Esperado:</strong> 13</span>\n",
    "      <button class=\"btn-sim\" id=\"btn-train\" onclick=\"iniciarEntrenamiento()\">Iniciar Entrenamiento (Backpropagation)</button>\n",
    "    </div>\n",
    "  </div>\n",
    "\n",
    "  <div class=\"sim-box\" style=\"opacity: 0.4; pointer-events: none;\" id=\"fase2\">\n",
    "    <div class=\"sim-header\" style=\"background:#16a34a;\">Fase 2: Inferencia (Predicción)</div>\n",
    "    <p style=\"text-align:center; font-size:0.9rem; color:#475569;\">La IA ya ha aprendido los pesos correctos. Ahora, dale datos nuevos (imágenes o textos que nunca ha visto) y predecirá al instante.</p>\n",
    "    \n",
    "    <div class=\"controls\" style=\"margin-bottom: 1.5rem; justify-content: space-around;\">\n",
    "      <label>Nueva Entrada x₁: <input type=\"number\" id=\"inf-x1\" value=\"5\" style=\"width:60px;\" onchange=\"predecir()\"></label>\n",
    "      <label>Nueva Entrada x₂: <input type=\"number\" id=\"inf-x2\" value=\"4\" style=\"width:60px;\" onchange=\"predecir()\"></label>\n",
    "    </div>\n",
    "\n",
